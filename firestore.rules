rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() &&
        (currentUser().role == 'Admin' || currentUser().role == 'Project Manager');
    }

    function isProjectMemberFromProject(projectId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    function isProjectMember(memberIds) {
      return signedIn() &&
        request.auth.uid in memberIds;
    }

    function isIssueAssignee() {
      return signedIn() && resource.data.assigneeId == request.auth.uid;
    }

    function memberIssueFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'status',
        'memberReportedDone',
        'memberReportedDoneAt',
        'memberReportedDoneBy',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAdmin() || isProjectMember(resource.data.memberIds);
      allow create: if isAdmin() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /issues/{issueId} {
      allow read: if isAdmin() || isProjectMemberFromProject(resource.data.projectId);
      allow create: if isAdmin() &&
        isProjectMemberFromProject(request.resource.data.projectId);
      allow update: if isAdmin() || (
        isIssueAssignee() &&
        memberIssueFieldsOnly()
      );
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAdmin() || isProjectMemberFromProject(resource.data.projectId);
      allow create: if signedIn() &&
        isProjectMemberFromProject(request.resource.data.projectId) &&
        request.resource.data.authorId == request.auth.uid;
      allow update, delete: if false;
    }

    match /standups/{standupId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (
        request.auth.uid == standupId ||
        isAdmin()
      );
    }
  }
}
